#!/bin/sh
######################################################################
# File: dk0
#
# Recommendation: Place this file in source control.
# It bootstraps dk0 if needed, then invokes it from this repository.
######################################################################

set -euf

DK_PROJECT_DIR=$(dirname "$0")
DK_PROJECT_DIR=$(cd "$DK_PROJECT_DIR" && pwd)

if [ -n "${COMSPEC:-}" ] && [ -x /usr/bin/cmd ] && [ -x /usr/bin/cygpath ] && [ -e "$DK_PROJECT_DIR/dk0.cmd" ]; then
    DK_PROJECT_DIR_WIN=$(/usr/bin/cygpath -aw "$DK_PROJECT_DIR")
    exec /usr/bin/cmd /c "$DK_PROJECT_DIR_WIN\\dk0.cmd" "$@"
fi

majminpat_ver=2.4.2.179
cksum256_darwin_arm64=4ca7d854796f67f971fe3dc9126ee5b01b8c9b82e9e41fc7ecb323d482eb61df
cksum256_darwin_x86_64=8679729333a5dcf9eefb4ea8d54ab407c2fc6c91bbe29d3b23017608e6e035f5
cksum256_linux_x86_64=ee1963aeda9e2c5f0b219d0bb61359feeca881d06140097d7d30afed6f077a6f
cksum256_linux_x86=ebf181a967a45d38dd2a6bc477fc48db44f5b305a0fa0300a1d0a51efcab0258

dk_pwd=$PWD

download_to_build() {
    abi=$1
    checksum=$2
    extexe=
    case "$abi" in
      windows_*) extexe=.exe ;;
    esac
    install -d build
    outfile="build/dk0-$abi$extexe"
    if [ ! -f "$outfile" ]; then
        curl -fsSL -o "$outfile" "https://gitlab.com/api/v4/projects/60486861/packages/generic/dk0/$majminpat_ver/dk0-$abi$extexe"
    fi
    actual=$(sha256sum "$outfile" | awk '{print $1}')
    [ "$actual" = "$checksum" ]
}

uname_s=$(uname -s)
uname_m=$(uname -m)
case "$uname_s:$uname_m" in
  Darwin:arm64) abi=darwin_arm64; checksum=$cksum256_darwin_arm64 ;;
  Darwin:x86_64) abi=darwin_x86_64; checksum=$cksum256_darwin_x86_64 ;;
  Linux:x86_64) abi=linux_x86_64; checksum=$cksum256_linux_x86_64 ;;
  Linux:i686|Linux:i386) abi=linux_x86; checksum=$cksum256_linux_x86 ;;
  *)
    echo "Unsupported host for ./dk0 bootstrap." >&2
    exit 1
    ;;
esac

download_to_build "$abi" "$checksum"
exec "$DK_PROJECT_DIR/build/dk0-$abi" -isystem "$DK_PROJECT_DIR/etc/dk/i" --cell "dk0=$DK_PROJECT_DIR" "$@"
